{
  "name": "@aigovops/verify",
  "version": "0.1.0",
  "description": "Reference verifier for the AiGovOps Open Standard (AOS): recompute HMAC-chained audit logs, verify SHA-256 of attestation PDFs, and fetch public attestation feeds.",
  "keywords": [
    "aigovops",
    "aos",
    "audit",
    "hmac",
    "sha256",
    "attestation",
    "compliance",
    "ai-governance",
    "slsa",
    "sigstore"
  ],
  "license": "Apache-2.0",
  "author": "AiGovOps Open Standard contributors",
  "homepage": "https://github.com/aigovops/aos",
  "repository": {
    "type": "git",
    "url": "https://github.com/aigovops/aos.git",
    "directory": "packages/verify"
  },
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "bin": {
    "aigovops-verify": "./dist/cli.js"
  },
  "scripts": {
    "build": "tsup src/index.ts src/cli.ts --format esm,cjs --dts --clean",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "tsc --noEmit",
    "prepublishOnly": "npm run lint && npm test && npm run build"
  },
  "engines": {
    "node": ">=18"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "tsup": "^8.0.0",
    "typescript": "^5.4.0",
    "vitest": "^1.6.0"
  }
}
